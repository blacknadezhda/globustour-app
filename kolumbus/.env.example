# ===== Telegram =====
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# ID участников команды (Нико, Виктория, менеджеры) через запятую — включает режим КОМАНДА
TEAM_USER_IDS=
# Чат команды: сюда прилетают пинги о новых лидах
TEAM_CHAT_ID=
# Чат, где слушает Глоба (для делегирования). Пусто = делегирование выключено
GLOBA_CHAT_ID=

# ===== Claude =====
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-opus-4-8
CLAUDE_MAX_TOKENS=2048

# ===== All Inclusive CRM =====
CRM_BASE_URL=https://api.allinclusivecrm.com/v1
CRM_TOKEN=
# userId менеджера, на которого назначаются новые лиды (например, Татьяны)
CRM_DEFAULT_USER_ID=
LEAD_SOURCE=Telegram

# ===== Монитор (сторож) =====
HEARTBEAT_FILE=data/heartbeat
HEARTBEAT_STALE_SEC=180
# Кому слать алерты (ты и Виктория), ID через запятую
ALERT_CHAT_IDS=
